{
  "description": "A field that is sometimes null merges to a sorted nullable type union.",
  "samples": [{ "deleted_at": null, "id": 1 }, { "deleted_at": "2026-01-01", "id": 2 }],
  "expected_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
      "deleted_at": { "type": ["null", "string"] },
      "id": { "type": "integer" }
    },
    "required": ["deleted_at", "id"],
    "type": "object"
  }
}
