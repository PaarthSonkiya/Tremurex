#!/bin/sh
# Pre-commit: lint + tests must pass (CLAUDE.md §5 tooling).
set -e

echo "pre-commit: lint"
pnpm lint

echo "pre-commit: TS tests"
pnpm test

for service in schema-engine proxy; do
  if [ -f "services/$service/pyproject.toml" ]; then
    echo "pre-commit: $service ruff + pytest"
    (cd "services/$service" && uv run ruff check . && uv run pytest -q)
  fi
done
