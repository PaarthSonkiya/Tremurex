# Tremurex configuration. Copy to .env and adjust.
# Secrets come from env only — never commit a real .env (CLAUDE.md §11).

# --- Postgres ---
POSTGRES_USER=tremurex
POSTGRES_PASSWORD=tremurex # change for any non-local deployment
POSTGRES_DB=tremurex
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Services (host-exposed ports) ---
CORE_PORT=4000
WEB_PORT=3000
SCHEMA_ENGINE_PORT=8000

# --- Passive proxy (Phase 3; only with `docker compose --profile proxy up`) ---
PROXY_PORT=8080
# How often the sidecar refreshes the set of monitored hosts from core.
PROXY_REFRESH_SECONDS=30

# --- Core ---
LOG_LEVEL=info
# Hard cap on a single captured response body, in bytes. A monitored endpoint
# is untrusted, so an unbounded read is a memory-exhaustion DoS. Default 10 MiB.
# TREMUREX_MAX_RESPONSE_BYTES=10485760
# Max nesting depth of captured JSON. Deeply nested JSON parses fine but would
# overflow the recursive redactor/diff walker — a stack-exhaustion DoS lever.
# Real-world JSON is rarely deeper than ~20. Default 100.
# TREMUREX_MAX_JSON_DEPTH=100

# --- Core API security ---
# Optional bearer token. When set (min 16 chars), every API route except
# /health requires `Authorization: Bearer <token>`. Unset = no auth (default).
# The CLI reads the same var; the web UI reads VITE_API_TOKEN at build time.
# TREMUREX_API_TOKEN=
# CORS allow-list for the browser UI (comma-separated origins). Defaults to the
# local web UI (http://localhost:3000, http://127.0.0.1:3000). Use '*' to
# reflect any origin (not recommended).
# TREMUREX_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# SSRF: link-local/cloud-metadata (169.254.x, fe80::, IMDSv6) is ALWAYS blocked.
# Set this to also block private/loopback ranges (turn OFF if you monitor
# internal APIs). Default: false (private ranges allowed).
# TREMUREX_BLOCK_PRIVATE_IPS=false

# --- Alerting (all optional; a channel is off until configured) ---
# Minimum severity that triggers a push alert (BREAKING | WARNING | INFO).
# INFO drift is always recorded to the timeline regardless.
ALERT_THRESHOLD=WARNING
# Generic webhook: drift alerts are POSTed here as JSON.
# ALERT_WEBHOOK_URL=https://example.com/tremurex-alerts
# Slack: bot token + channel to post drift alerts to.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL=#api-drift
# Email (SMTP): active only when host, from, and to are all set. User/pass are
# optional (some relays accept unauthenticated mail); SMTP_SECURE=true for the
# implicit-TLS port 465, otherwise STARTTLS is used where offered.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=...
# ALERT_EMAIL_FROM=Tremurex <alerts@example.com>
# ALERT_EMAIL_TO=oncall@example.com,team@example.com

# Set automatically inside docker compose; needed only when running core
# directly on the host (pnpm --filter @tremurex/core dev):
# DATABASE_URL=postgres://tremurex:tremurex@localhost:5432/tremurex
# REDIS_URL=redis://localhost:6379
# SCHEMA_ENGINE_URL=http://localhost:8000
